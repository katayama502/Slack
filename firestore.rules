rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isChannelMember(channelId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/channels/$(channelId)).data.members;
    }

    // ─────────────────────────────────────────────
    // channels/{channelId}
    // ─────────────────────────────────────────────
    match /channels/{channelId} {

      // 読み取り: 認証済みユーザーなら誰でも可（チャンネル一覧表示のため）
      allow read: if isAuthenticated();

      // 作成: 認証済みユーザー（自分を members に含める）
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // 更新:
      //   - メンバーは name/description/members を更新可
      //   - 非メンバーでも「自分自身を members に追加する（参加）」のみ許可（DM除く）
      allow update: if isAuthenticated() && (
        (
          isChannelMember(channelId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'members'])
        ) || (
          !resource.data.get('isDM', false) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members
        )
      );

      // 削除: 作成者のみ
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;

      // ─────────────────────────────────────────
      // pins
      // ─────────────────────────────────────────
      match /pins/{pinId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.createdBy == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.createdBy == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.createdBy == request.auth.uid;
      }

      // ─────────────────────────────────────────
      // typing
      // ─────────────────────────────────────────
      match /typing/{uid} {
        allow read: if isChannelMember(channelId);
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }

      // ─────────────────────────────────────────
      // messages
      // ─────────────────────────────────────────
      match /messages/{messageId} {

        allow read, create: if isChannelMember(channelId);

        // 削除: 自分のメッセージのみ
        allow delete: if isAuthenticated()
          && resource.data.uid == request.auth.uid;

        // 更新: 自分のメッセージは何でも可 / 他人のメッセージは reactions フィールドのみ可
        allow update: if isAuthenticated() && (
          resource.data.uid == request.auth.uid
          ||
          (
            isChannelMember(channelId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          )
        );

        match /threads/{threadId} {
          allow read, create: if isChannelMember(channelId);
          // 削除・テキスト編集: 自分の返信のみ
          allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
          // 更新: 自分の返信は何でも可 / 他人の返信は reactions フィールドのみ可
          allow update: if isAuthenticated() && (
            resource.data.uid == request.auth.uid
            ||
            (
              isChannelMember(channelId) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            )
          );
        }
      }
    }

    // ─────────────────────────────────────────────
    // users/{userId}
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ─────────────────────────────────────────────
    // notifications
    // ─────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      // 自分の通知のみ読み取り・更新・削除可
      allow read, update, delete: if isOwner(userId);
      // 認証済みユーザーなら誰でも他ユーザーへの通知を作成可（fromUserが自分のUID）
      allow create: if isAuthenticated() && request.resource.data.fromUser == request.auth.uid;
    }
  }
}
